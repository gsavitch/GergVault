DEBUG=1
SECRET_KEY=open-card-vault-dev-secret
ALLOWED_HOSTS=localhost,127.0.0.1,gerg.savitch.fun
CSRF_TRUSTED_ORIGINS=https://gerg.savitch.fun
SESSION_COOKIE_NAME=gergvault_sessionid
CSRF_COOKIE_NAME=gergvault_csrftoken
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_HSTS_SECONDS=0
GERGVAULT_SERVE_MEDIA=1
GERGVAULT_TRACK_TRAFFIC=1
GERGVAULT_RATE_LIMIT_ENABLED=1
GERGVAULT_LOGIN_RATE_LIMIT=20
GERGVAULT_SIGNUP_RATE_LIMIT=10
GERGVAULT_UPLOAD_RATE_LIMIT=30
GERGVAULT_API_UPLOAD_RATE_LIMIT=30

# Leave POSTGRES_DB blank to use SQLite locally.
POSTGRES_DB=
POSTGRES_USER=opencardvault
POSTGRES_PASSWORD=opencardvault
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
WEB_PORT=8000
WEB_WORKERS=2
WEB_TIMEOUT=120
DEFAULT_FROM_EMAIL=noreply@gergvault.halobridge.ai
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Optional providers. The app runs without these.
OPENAI_API_KEY=
CARD_VAULT_OPENAI_MODEL=
BRAVE_SEARCH_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
PRICECHARTING_API_KEY=
SPORTSCARDSPRO_API_KEY=
PSA_API_KEY=
